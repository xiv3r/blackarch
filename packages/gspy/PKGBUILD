# Maintainer: Mutasem Kharma <mutasem@gspy.dev>
# SPDX-License-Identifier: GPL-2.0-only
pkgname=gspy
pkgver=0.1.1
pkgrel=1
pkgdesc='Forensic goroutine-to-syscall inspector for live Go processes.'
arch=('x86_64' 'aarch64')
url='https://github.com/Mutasem-mk4/gspy'
license=('GPL-2.0-or-later')
groups=('blackarch' 'blackarch-forensic' 'blackarch-debugger')
depends=('glibc')
makedepends=('go>=1.21' 'clang>=14' 'llvm>=14' 'libbpf' 'bpf'
             'linux-api-headers')
source=("$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('9ac6311d15ae7404ffa1a0b5bedddf9d2c0b07047503d1f9016d54d8474ae0d7')

prepare() {
  cd "$pkgname-$pkgver"

  export PATH=$PATH:$(go env GOPATH)/bin

  go install github.com/cilium/ebpf/cmd/bpf2go@v0.14.0
}

build() {
  cd "$pkgname-$pkgver"

  export CGO_ENABLED=0
  export PATH=$PATH:$(go env GOPATH)/bin

  # Generate vmlinux.h from running kernel BTF if available
  if [ -f /sys/kernel/btf/vmlinux ]; then
    bpftool btf dump file /sys/kernel/btf/vmlinux format c > bpf/vmlinux.h
  fi

  make generate
  make build VERSION=$pkgver
}

package() {
  cd "$pkgname-$pkgver"

  install -Dm 755 "bin/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm 644 "man/$pkgname.1" "$pkgdir/usr/share/man/man1/$pkgname.1"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md
  install -Dm 644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

