pkgname=sshprank
pkgver=1.6.0
pkgrel=2
groups=('blackarch' 'blackarch-cracker' 'blackarch-scanner'
        'blackarch-fingerprint')
pkgdesc='A fast SSH mass-scanner, login cracker, banner grabber and password auth checker tool using the python-masscan and shodan module.'
url='https://nullsecurity.net/tools/cracker.html'
license=('custom:unknown')
arch=('any')
depends=('python' 'python-python-masscan' 'python-paramiko' 'python-shodan')
source=("https://github.com/nullsecuritynet/tools/raw/main/cracker/$pkgname/release/$pkgname-$pkgver.tar.gz")
sha512sums=('fbb3ffc6855996f1e3636ef3f207a5717d7855b0fb67960d35c504fa6ad623c90f755035a375744ae232d481274c70bb3179e6bc580ed6d060a6347e004b224a')

package() {
  cd "$pkgname-$pkgver"

  install -dm 755 "$pkgdir/usr/share/$pkgname"

  install -Dm 755 "$pkgname.py" "$pkgdir/usr/bin/$pkgname"
  cp -a lists "$pkgdir/usr/share/$pkgname/"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md docs/TODO
}

