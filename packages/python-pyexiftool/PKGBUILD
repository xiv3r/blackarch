pkgname=python-pyexiftool
_pkgname=PyExifTool
pkgver=0.5.6
pkgrel=1
epoch=1
pkgdesc='Python wrapper for exiftool.'
arch=('any')
url='https://pypi.org/project/PyExifTool/#files'
license=('GPL')
depends=('python')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('176456f44ad7c8b3e2a57b1e33a49349f479d6a470ca8fcb93025395596083b77c1e12e2555bbfac8ac22f045fe7ef3bdc608d095d5a49406b95ae971d5390d7')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {
  cd "$_pkgname-$pkgver"

  python setup.py install --prefix=/usr --root="$pkgdir" --optimize=1 \
    --skip-build
}

